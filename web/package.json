{
  "name": "code-rag-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web UI (M1) for code-rag — streaming chat + clickable citations + live trace + manual-search. Consumes the HTTP wire (ADR-008); never imports the Node package.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "biome check . && tsc --noEmit && vitest run && vite build"
  },
  "dependencies": {
    "@shikijs/langs": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.4",
    "ws": "^8.18.0"
  }
}
