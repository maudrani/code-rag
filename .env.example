# Config for code-rag. Copy to `.env` — it's auto-loaded by the CLI, the HTTP server, and the MCP.
# Real shell exports and Docker/compose env ALWAYS take precedence, so this file never overrides them.
# No secret is committed here.

# The ONLY key clone-and-run needs — and only for a STREAMED `ask`. search / stats / `ask --dry` need none.
ANTHROPIC_API_KEY=

# The codebase to index. Default = this repo (self-index). Point at a subtree for a big codebase.
CORPUS_PATH=.

# ── Retrieval knobs (all optional) ─────────────────────────────────────────────────────────────
# CODE_RAG_DENSE=true                     # opt into the local ONNX semantic leg (higher recall).
#                                         # OFF by default: BM25 + structural is instant, fully offline,
#                                         # and never freezes. Enabling it over a WHOLE repo is refused
#                                         # with an actionable message — scope CORPUS_PATH first.
# CODE_RAG_INDEX=.code-rag/index.db       # persist the index → warm restarts (re-embed only changed files)
# CODE_RAG_LEDGER=.code-rag/ledger.jsonl  # the shared cross-consumer query ledger the web dashboard tails
