{
  "name": "code-rag",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "code-rag": "dist/src/cli/index.js"
  },
  "description": "Conversational RAG assistant over a codebase — answers how code works / where things live / endpoints / deps, grounded in retrieved code with clickable citations. Deterministic-gradient architecture. (NewPage FDE take-home; product name is a placeholder.)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const fs=require('fs'),p='src/chunk/grammars',o='dist/'+p;fs.mkdirSync(o,{recursive:true});for(const f of fs.readdirSync(p))if(f.endsWith('.wasm'))fs.copyFileSync(p+'/'+f,o+'/'+f)\"",
    "serve": "tsx src/http/server.ts",
    "cli": "tsx src/cli/index.ts",
    "mcp": "tsx src/mcp/serve.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "ci": "biome ci . && tsc --noEmit && vitest run",
    "check": "biome check --write . && tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@hono/node-server": "^1.13.0",
    "@hono/node-ws": "^1.0.4",
    "@huggingface/transformers": "^3.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.8.0",
    "hono": "^4.6.0",
    "web-tree-sitter": "^0.24.0",
    "zod": "^3.23.8"
  },
  "overrides": {
    "onnxruntime-node": "1.24.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.0",
    "fast-check": "^3.23.2",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "ws": "^8.21.0"
  }
}
